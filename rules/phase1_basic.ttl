@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://mythesis.org/rules/> .

# 定义一个针对“公寓整体”的验证形状
ex:FunctionalSpaceCheck
    a sh:NodeShape ;
    # 1. 锁定目标：所有类型为 bot:Zone 且作为根节点的公寓
    # (这里简单起见，假设你的根节点是 bot:Zone)
    sh:targetClass bot:Zone ;

    # ============================================
    # 规则 A: 必须有卧室 (Bedroom)
    # ============================================
    sh:property [
        sh:path bot:containsZone ;  # 检查路径：公寓包含的区域
        sh:qualifiedValueShape [    # 限定条件：该区域必须...
            sh:path rdfs:label ;    # ...在 label 属性上...
            sh:pattern "Bedroom" ;  # ...包含 "Bedroom" 字符串
            sh:flags "i" ;          # (忽略大小写)
        ] ;
        sh:qualifiedMinCount 1 ;    # 满足上述条件的区域至少要有 1 个
        sh:message "❌ 违反规范 3.1.1：缺少【卧室】功能空间。" ;
    ] ;

    # ============================================
    # 规则 B: 必须有起居厅 (Living Room)
    # ============================================
    sh:property [
        sh:path bot:containsZone ;
        sh:qualifiedValueShape [
            sh:path rdfs:label ;
            sh:pattern "Living|Lounge" ; # 支持多种叫法
            sh:flags "i" ;
        ] ;
        sh:qualifiedMinCount 1 ;
        sh:message "❌ 违反规范 3.1.1：缺少【起居厅】功能空间。" ;
    ] ;

    # ============================================
    # 规则 C: 必须有厨房 (Kitchen)
    # ============================================
    sh:property [
        sh:path bot:containsZone ;
        sh:qualifiedValueShape [
            sh:path rdfs:label ;
            sh:pattern "Kitchen|Cook" ;
            sh:flags "i" ;
        ] ;
        sh:qualifiedMinCount 1 ;
        sh:message "❌ 违反规范 3.1.1：缺少【厨房】功能空间。" ;
    ] ;

    # ============================================
    # 规则 D: 必须有卫生间 (Bathroom)
    # ============================================
    sh:property [
        sh:path bot:containsZone ;
        sh:qualifiedValueShape [
            sh:path rdfs:label ;
            sh:pattern "Bath|Toilet|Restroom" ;
            sh:flags "i" ;
        ] ;
        sh:qualifiedMinCount 1 ;
        sh:message "❌ 违反规范 3.1.1：缺少【卫生间】功能空间。" ;
    ] .